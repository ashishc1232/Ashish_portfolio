# Email Configuration (Gmail or your email service)
# To use Gmail, you'll need to:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password from: https://myaccount.google.com/apppasswords
# 3. Use your email as EMAIL_USER and the generated App Password as EMAIL_PASSWORD

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Optional: If using a different email service
# EMAIL_SERVICE=gmail
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587

# Contact Information (displayed in contact section)
NEXT_PUBLIC_PHONE=+1 (234) 567-8900
NEXT_PUBLIC_LOCATION=City, Country
